      "pattern": "^[0-9a-fA-F]{64}$",
      "type": "string"
    },
    "trace_final_hash": {
      "pattern": "^[0-9a-fA-F]{64}$",
      "type": "string"
    },
    "weights_manifest_hash": {
      "pattern": "^[0-9a-fA-F]{64}$",
      "type": "string"
