{
  "$id": "glyphser:l2:data-lineage",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "data_access_plan_hash": {
      "type": "string"
    },
    "dataset_snapshot_id": {
      "minLength": 1,
      "type": "string"
    },
    "lineage_root_hash": {
      "type": "string"
    },
    "split_hashes": {
      "items": {
        "type": "object"
