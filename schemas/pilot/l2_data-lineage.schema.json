      "type": "string"
    }
  },
  "required": [
    "dataset_snapshot_id",
    "data_access_plan_hash",
    "lineage_root_hash"
  ],
  "title": "Data-Lineage (L2)",
  "type": "object",
  "x_glyphser": {
    "hash_rule": "canonical_json_sha256",
    "layer": "L2",
    "prose_check": "relaxed",
    "schema_version": "0.1",
    "source_doc": "docs/layer2-specs/Data-Lineage.md"
  }
}
