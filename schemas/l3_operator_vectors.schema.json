{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "glyphser.schemas.l3.operator_vectors",
  "title": "Glyphser Operator Vectors",
  "type": "object",
  "additionalProperties": false,
  "required": ["operator_id", "vectors"],
  "properties": {
    "operator_id": {"type": "string", "minLength": 1},
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["case_id", "request", "expected"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "request": {"type": "object"},
          "expected": {
            "type": "object",
            "minProperties": 1,
            "properties": {
              "error": {"type": "object"},
              "response": {"type": "object"}
            }
          }
        }
      }
    }
  },
  "x_glyphser": {
    "schema_id": "glyphser.schemas.l3.operator_vectors",
    "source_doc": "specs/layers/L3-tests/Operator-Vectors.md",
    "compatibility_policy": "MAJOR",
    "layer": "L3",
    "schema_version": "1.0.0",
    "hash_rule": "sha256_canonical_json",
    "prose_check": "relaxed"
  }
}
