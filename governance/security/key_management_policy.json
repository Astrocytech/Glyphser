{
  "minimum_key_length": 32,
  "minimum_entropy_bits": 80,
  "maximum_rotation_age_days": 90,
  "maximum_rollover_window_days": 14,
  "enforce_sibling_key_mode_match": true,
  "rotation_record_path": "governance/security/key_rotation_record.json",
  "require_signed_rotation_record": true,
  "rotation_timestamp_env": "GLYPHSER_PROVENANCE_KEY_ROTATED_AT",
  "signing_key_env": "GLYPHSER_PROVENANCE_HMAC_KEY"
}
