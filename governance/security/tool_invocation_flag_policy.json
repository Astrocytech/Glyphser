{
  "tools": [
    {
      "id": "bandit",
      "match": "bandit -q -c tooling/security/bandit.yaml -r glyphser runtime tooling",
      "required_flags": [
        "-l",
        "-ii"
      ],
      "forbidden_flags": [
        "--skip",
        "-x"
      ]
    },
    {
      "id": "semgrep",
      "match": "semgrep --config tooling/security/semgrep-rules.yml",
      "required_flags": [
        "--error",
        "--output"
      ],
      "required_any_flags": [
        [
          "--sarif",
          "--json"
        ]
      ],
      "forbidden_flags": [
        "--quiet"
      ]
    },
    {
      "id": "pip-audit-gate",
      "match": "python tooling/security/pip_audit_gate.py",
      "forbidden_flags": [
        "--ignore-vuln",
        "--skip-editable"
      ]
    }
  ]
}
