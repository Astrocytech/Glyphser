name: {{ workflow_name }}

on:
  workflow_dispatch:
  schedule:
    - cron: "{{ cron_schedule }}"

jobs:
  {{ job_id }}:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    env:
      GLYPHSER_ENV: "{{ glyphser_env }}"
      GLYPHSER_EVIDENCE_ROOT: evidence/runs/${{ '{{ github.run_id }}' }}/{{ workflow_slug }}
      TZ: "UTC"
      LC_ALL: "C.UTF-8"
      LANG: "C.UTF-8"
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683
      - uses: actions/setup-python@42375524e23c412d93fb67b49958b491fce71c38
        with:
          python-version: "3.12"
      - name: Install package
        run: |
          python -m pip install --upgrade pip
          pip install -e .[dev]
      - name: Install pinned security tools
        run: python tooling/security/install_security_toolchain.py
      - name: Security preflight
        run: |
          semgrep --version
          python -c "import pkg_resources"
          python tooling/security/evidence_run_dir_guard.py --run-id "${{ '{{ github.run_id }}' }}-{{ workflow_slug }}"
      - name: Run gate
        run: python tooling/security/{{ gate_script }}
      - name: Upload security artifacts
        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02
        with:
          name: {{ workflow_slug }}-artifacts
          retention-days: 30
          path: |
            ${{ '{{ env.GLYPHSER_EVIDENCE_ROOT }}' }}/security/{{ gate_report }}
